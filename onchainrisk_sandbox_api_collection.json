{
  "info": {
    "_postman_id": "onchainrisk-sandbox-v1",
    "name": "OnChainRisk Sandbox API",
    "description": "Public sandbox tier — integration testing against real OnChainRisk API.\n\n**Setup (one-time, via dashboard — NOT via this collection):**\n1. Sign up at https://onchainrisk.io/register (CAPTCHA required)\n2. Dashboard → API Keys → Create sandbox key (1 max for free tier)\n3. Copy the key (shown once)\n4. In Postman: set env var `sandbox_api_key` to your key\n\nAll requests here use that key via `Authorization: Bearer {{sandbox_api_key}}`. Key management (create/rotate/revoke) lives in the dashboard — not exposed to sandbox because the self-service flow is intentional.\n\n**Sandbox gates expensive fields** — responses match paid shape but `crossChain`, `tokenFlow`, `clusters`, `honeypot`, etc. are always `null`/`[]`. See `_sandbox.gated_fields[]` in every response for the authoritative list.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://api.onchainrisk.io", "type": "string" },
    { "key": "sandbox_api_key", "value": "ocr_live_REPLACE_ME", "type": "string", "description": "Your sandbox API key. Create one in the dashboard: https://onchainrisk.io/dashboard/api-keys" },
    { "key": "sample_address", "value": "0xa39b189482f984388a34460636fea9eb181ad1a6", "type": "string", "description": "Light demo address — runs fast. Swap to your own for real integration testing." },
    { "key": "user_address", "value": "0xREPLACE_ME_WITH_YOUR_ADDRESS", "type": "string", "description": "Your own address for Request 3." }
  ],
  "item": [
    {
      "name": "1. Auth sanity — GET /api/user/me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{sandbox_api_key}}" }],
        "url": { "raw": "{{base_url}}/api/user/me", "host": ["{{base_url}}"], "path": ["api", "user", "me"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('has key_type=sandbox', () => pm.expect(body.data.key_type).to.equal('sandbox'));",
              "pm.test('has api_mode=sandbox', () => pm.expect(body.data.api_mode).to.equal('sandbox'));",
              "pm.test('plan is real (not overridden to sandbox)', () => pm.expect(['free','pro','business','enterprise']).to.include(body.data.plan));"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Check address — sample (Vitalik-light)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{sandbox_api_key}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"address\": \"{{sample_address}}\",\n  \"network\": \"eth\"\n}"
        },
        "url": { "raw": "{{base_url}}/api/v1/check", "host": ["{{base_url}}"], "path": ["api", "v1", "check"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const d = pm.response.json().data;",
              "pm.test('_sandbox block present', () => pm.expect(d._sandbox).to.be.an('object'));",
              "pm.test('_sandbox.profile = sandbox', () => pm.expect(d._sandbox.profile).to.equal('sandbox'));",
              "pm.test('_sandbox.reports_saved = false', () => pm.expect(d._sandbox.reports_saved).to.equal(false));",
              "pm.test('gated: crossChain is null', () => pm.expect(d.crossChain).to.equal(null));",
              "pm.test('gated: tokenFlow is null', () => pm.expect(d.tokenFlow).to.equal(null));",
              "pm.test('gated: clusters is null', () => pm.expect(d.clusters).to.equal(null));",
              "pm.test('gated: topCounterparties is []', () => pm.expect(d.topCounterparties).to.eql([]));",
              "pm.test('no reportId (sandbox does not persist)', () => pm.expect(d).to.not.have.property('reportId'));",
              "pm.test('no analysisMode (omitted by policy)', () => pm.expect(d).to.not.have.property('analysisMode'));"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Check address — your own address",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{sandbox_api_key}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"address\": \"{{user_address}}\",\n  \"network\": \"eth\"\n}"
        },
        "url": { "raw": "{{base_url}}/api/v1/check", "host": ["{{base_url}}"], "path": ["api", "v1", "check"] },
        "description": "Replace `user_address` env var with any address. Same sandbox shape as Request 2."
      }
    },
    {
      "name": "5. Blocked endpoint — /check/deep returns 403",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{sandbox_api_key}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"address\": \"{{sample_address}}\",\n  \"network\": \"eth\"\n}"
        },
        "url": { "raw": "{{base_url}}/api/v1/check/deep", "host": ["{{base_url}}"], "path": ["api", "v1", "check", "deep"] },
        "description": "Peel chain / deep analysis is a paid-tier feature. Sandbox keys receive 403 with upgrade pointer."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('403 sandbox_not_supported', () => pm.response.to.have.status(403));",
              "const d = pm.response.json();",
              "pm.test('has upgrade_url', () => pm.expect(d.upgrade_url).to.include('pricing'));"
            ]
          }
        }
      ]
    },
    {
      "name": "6. Invalid address — 400",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{sandbox_api_key}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"address\": \"not-a-valid-address\",\n  \"network\": \"eth\"\n}"
        },
        "url": { "raw": "{{base_url}}/api/v1/check", "host": ["{{base_url}}"], "path": ["api", "v1", "check"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('400 on invalid address', () => pm.response.to.have.status(400));"
            ]
          }
        }
      ]
    },
    {
      "name": "7. Fetch API-level docs (OpenAPI spec)",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{base_url}}/openapi-sandbox.yaml", "host": ["{{base_url}}"], "path": ["openapi-sandbox.yaml"] },
        "description": "Raw OpenAPI 3.1 spec for code generators (openapi-generator, orval, etc.). No auth required."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "pm.test('yaml content type', () => {",
              "  const ct = pm.response.headers.get('Content-Type') || '';",
              "  pm.expect(ct.includes('yaml') || ct.includes('text/plain') || ct.includes('application/x-yaml')).to.equal(true);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
